# ─────────────────────────────────────────────────────────────
# Astra API — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git. Add it to .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://astra:astra_secret@localhost:5432/astra

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (OBRIGATÓRIO) ─────────────────────────────────
# Gere strings fortes com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Mínimo 32 caracteres — strings curtas rejeitadas no startup.
JWT_ACCESS_SECRET=CHANGE_ME_use_a_random_string_of_at_least_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_use_a_different_random_string_of_at_least_32_chars

# ── Google OAuth (OBRIGATÓRIO) ────────────────────────────────
# Cria em https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── URLs (OBRIGATÓRIO) ────────────────────────────────────────
# CLIENT_URL é usado pra CORS allowlist + redirects de OAuth.
# Em prod, troque pra domínio final (ex.: https://astra.app)
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:3001

# ── Anthropic (opcional — bot UI fica em fallback sem) ────────
# Cria em https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Web Push notifications (opcional) ─────────────────────────
# Gera com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@astra.local

# ── Giphy GIF picker (opcional — picker fica oculto sem) ──────
# Pega chave em https://developers.giphy.com → Create an App → API
GIPHY_API_KEY=

# ── LiveKit voice/video (opcional — chamadas off sem) ─────────
# Cria conta em livekit.io → Project → Settings → URL + API keys
# Free tier: 100GB egress/mês (~140h de áudio puro)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Observabilidade (opcional) ────────────────────────────────
# Sentry: DSN em sentry.io → projeto Node → Settings → Client Keys
SENTRY_DSN=
SENTRY_TRACES_SAMPLE=0.1
SENTRY_ENVIRONMENT=
# Release pra correlacionar erros com commit (ex.: SHA do CI)
RELEASE=

# Prometheus /metrics — em prod, exige Bearer <METRICS_TOKEN>.
# Sem token, endpoint vira 404 em prod (escondido).
METRICS_TOKEN=

# debug | info | warn | error  (default: info em prod, debug em dev)
LOG_LEVEL=
