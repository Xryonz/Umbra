# ── Dependencies ────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ───────────────────────────────────────────
dist/
build/
*.tsbuildinfo
.turbo/
.next/
out/

# ── Coverage / cache ────────────────────────────────────────
coverage/
.vite/
.cache/
.nyc_output/

# ── Env / secrets (NUNCA commitar) ─────────────────────────
# Service account do Firebase (chave privada do FCM) — vive só no
# Railway (env FIREBASE_SERVICE_ACCOUNT) e nesta máquina.
*firebase-adminsdk*.json
# Keystore de release do Android + credenciais: perder = não atualizar
# mais o app; vazar = qualquer um assina como Astra. FAZER BACKUP fora
# do repo (drive/pendrive).
*.keystore
*.jks
apps/web/android/keystore.properties
# Config do app Firebase: não é segredo crítico, mas o repo é PÚBLICO —
# expor a API key convida abuso de quota. Clone novo: baixar de novo no
# console Firebase (ver apps/web/MOBILE.md).
apps/web/android/app/google-services.json
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Allow examples (sanitized, no secrets)
!.env.example

# ── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── User-uploaded files (runtime data, não pertence ao repo) ─
apps/api/uploads/

# ── Capacitor: android/ É versionado (recomendação oficial) ──
# Mudanças nativas (deep link, permissões, PiP, quick reply) vivem lá;
# o .gitignore interno do android/ já exclui build/, local.properties etc.
apps/web/ios/

# ── Bundle analyzer output ──────────────────────────────────
stats.html
dist/stats.html

# ── Playwright output ───────────────────────────────────────
